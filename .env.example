# ─────────────────────────────────────────────────────────────
# Autonomous Stock Trading Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Groww (Live Trading Only) ──────────────────────────────────
# Required ONLY if TRADING_MODE=live
# Get your JWT token from Groww mobile app's network requests
# (Use app → Settings → Profile → open browser devtools/network tab)
# WARNING: Keep this secret. Anyone with this token can trade on your account.
GROWW_AUTH_TOKEN=

# ── Trading Mode ──────────────────────────────────────────────
# 'paper'  = simulated trading (safe, no real money) [DEFAULT]
# 'live'   = real trades on Groww (USE WITH EXTREME CAUTION)
TRADING_MODE=paper

# ── Paper Trading Settings ────────────────────────────────────
# Initial virtual balance for paper trading (in INR)
INITIAL_BALANCE=100000

# ── Risk Management ───────────────────────────────────────────
# Maximum % of portfolio in a single stock (default: 10)
MAX_POSITION_PCT=10

# Stop all trading if daily loss exceeds this % (default: 3)
MAX_DAILY_LOSS_PCT=3

# Maximum simultaneous stock positions (default: 10)
MAX_OPEN_POSITIONS=10

# Maximum trades per day (default: 20)
MAX_TRADES_PER_DAY=20

# Stop-loss: sell if stock drops this % from avg buy price (default: 5)
STOP_LOSS_PCT=5

# ── Optional: Alpha Vantage (News Sentiment Scoring) ──────────
# Free tier: 25 requests/day (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=
